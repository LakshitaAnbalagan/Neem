{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/socket.io/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*\\.(html|css|js|png|jpg|jpeg|gif|svg|ico|webp|woff2?))", "dest": "frontend/public/$1" },
    { "src": "/(.*)", "dest": "frontend/public/index.html" }
  ]
}
